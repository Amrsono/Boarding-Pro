# GoldenBoarding Configuration Guide

# 1. Core API Keys
NEWS_API_KEY=your_news_api_key_from_newsapi_org
OPENAI_API_KEY=your_openai_api_key_here

# 2. Database
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/your_db_name
DB_NAME=golden_boarding

# 3. Admin Credentials
ADMIN_USER=admin
ADMIN_PASS=golden2024

# 4. Settings
PORT=3000
OPENAI_MODEL=gpt-4o-mini
INTENT_HOT_THRESHOLD=35

# 5. Alerts (Optional)
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
# ALERT_WEBHOOK_AUTH=Optional_Bearer_Token
